# ─── Withings OAuth2 ──────────────────────────────────────────────
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://127.0.0.1:8010/api/withings/auth/callback
WITHINGS_SCOPE=user.metrics

# ─── Application ─────────────────────────────────────────────────
APP_BASE_URL=http://127.0.0.1:8010
APP_HOST=127.0.0.1
APP_PORT=8010
APP_TIMEZONE=Europe/Paris
USER_HEIGHT_M=
ADMIN_API_TOKEN=

# ─── Garmin MCP / Garmin Connect ─────────────────────────────────
GARMIN_MCP_SOURCE=git+https://github.com/Taxuspt/garmin_mcp
GARMIN_TOKEN_DIR=/home/app/.garminconnect
GARMIN_AUTH_COMMAND=uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp-auth
GARMIN_VERIFY_COMMAND=uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp-auth --verify

# ─── Paths ───────────────────────────────────────────────────────
DATA_DIR=./data
LOG_DIR=./logs
RUNTIME_DIR=./runtime

# ─── Sync behaviour ──────────────────────────────────────────────
SYNC_REQUIRES_ACTIVE_CONNECTIONS=true

# ─── Anti-duplicate thresholds ───────────────────────────────────
WEIGHT_DUPLICATE_EPSILON_KG=0.05
WEIGHT_CONFLICT_EPSILON_KG=0.2
GARMIN_LOOKBACK_DAYS=7
GARMIN_LOOKAHEAD_DAYS=1
WITHINGS_PER_DAY_STRATEGY=latest_per_day

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=jsonl
