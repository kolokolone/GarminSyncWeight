# ─── Withings OAuth2 ──────────────────────────────────────────────
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
# ── Pour accès LAN direct ──
# WITHINGS_REDIRECT_URI=http://192.168.1.100:8010/api/withings/auth/callback
# ── Pour accès reverse proxy HTTPS ──
# WITHINGS_REDIRECT_URI=https://garmin.mondomaine.fr/api/withings/auth/callback
WITHINGS_REDIRECT_URI=http://127.0.0.1:8010/api/withings/auth/callback
WITHINGS_SCOPE=user.metrics

# ─── Application ─────────────────────────────────────────────────
# ── Pour accès LAN direct ──
# APP_BASE_URL=http://192.168.1.100:8010
# ── Pour accès reverse proxy HTTPS ──
# APP_BASE_URL=https://garmin.mondomaine.fr
APP_BASE_URL=http://127.0.0.1:8010
APP_HOST=0.0.0.0
APP_PORT=8010
APP_TIMEZONE=Europe/Paris
USER_HEIGHT_M=
ADMIN_API_TOKEN=

# ─── Garmin MCP / Garmin Connect ─────────────────────────────────
GARMIN_MCP_SOURCE=git+https://github.com/Taxuspt/garmin_mcp
GARMIN_TOKEN_DIR=/home/app/.garminconnect
# Les commandes ci-dessous sont pour le développement local.
# En Docker, garmin-mcp-auth est installé dans l'image : utiliser
# GARMIN_AUTH_COMMAND=garmin-mcp-auth
# GARMIN_VERIFY_COMMAND=garmin-mcp-auth --verify
GARMIN_AUTH_COMMAND=uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp-auth
GARMIN_VERIFY_COMMAND=uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp-auth --verify

# ─── Paths (valeurs pour le conteneur Docker) ────────────────────
DATA_DIR=/app/data
LOG_DIR=/app/logs
RUNTIME_DIR=/app/runtime

# ─── Sync behaviour ──────────────────────────────────────────────
SYNC_REQUIRES_ACTIVE_CONNECTIONS=true

# ─── Anti-duplicate thresholds ───────────────────────────────────
WEIGHT_DUPLICATE_EPSILON_KG=0.05
WEIGHT_CONFLICT_EPSILON_KG=0.2
GARMIN_LOOKBACK_DAYS=7
GARMIN_LOOKAHEAD_DAYS=1
WITHINGS_PER_DAY_STRATEGY=latest_per_day

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=jsonl
